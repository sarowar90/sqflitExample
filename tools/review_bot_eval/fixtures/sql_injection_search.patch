+  /// Searches products by name or barcode.
+  ///
+  /// Moves the inventory search off the in-memory list so it keeps working
+  /// once the catalogue outgrows what we load up front.
+  Future<List<Product>> searchProducts(String query) async {
+    final db = await instance.database;
+    final maps = await db.rawQuery(
+      "SELECT * FROM products WHERE name LIKE '%$query%' OR barcode LIKE '%$query%' ORDER BY id DESC",
+    );
+
+    return maps.map((map) => Product.fromMap(map)).toList();
+  }
